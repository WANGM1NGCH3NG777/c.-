#include<stdio.h>

int binary_search(int* data, int len, int value)
{
	int low = 0;
	int high = len - 1;
	int mid = 0;
	while (low <= high)
	{
		mid = (high + low) / 2;
		if (value > data[mid])
		{
			low = mid + 1;
		}
		else if (value < data[mid])
		{
			high = mid - 1;
		}
		else
		{
			return mid;
		}
	}
	return -1;
}

int main()
{
	int arr[] = { 11, 13, 15, 27, 49, 68, 50, 44 };
	int len = sizeof(arr) / sizeof(arr[0]);
	int value = 0;
	printf("输入想要查找的数字：");
	scanf("%d", &value);
	int pos = binary_search(arr, len, value);
	if (pos == -1)
	{
		printf("数字 %d 不存在于数组中", value);
	}
	else
	{
		printf("数字 %d 在数组中的位置是 %d", value, pos);
	}
  
  return 0;
}
